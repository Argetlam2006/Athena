# Athena Environment Configuration
# Copy this file to .env and adjust as necessary

# Application Environment (development, demo, production)
ATHENA_ENV=development

# LLM Provider Selection (auto, claude, openai, gemini, demo)
ATHENA_PROVIDER=auto

# Optional API Keys (Only required if not using 'demo' provider)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here

# Telemetry and Logging Level (INFO, DEBUG, WARNING)
LOG_LEVEL=INFO
