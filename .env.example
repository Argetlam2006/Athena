# ─────────────────────────────────────────────────────────────────────────────
# Athena — Environment Variables
# Copy this file to .env and fill in your values.
# .env is in .gitignore — never commit it.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI API Keys (at least one required for Ask Athena / report generation) ───
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ── AI Provider (gemini | openai) ────────────────────────────────────────────
ATHENA_AI_PROVIDER=gemini

# ── Database ─────────────────────────────────────────────────────────────────
ATHENA_DB_PATH=data/warehouse/athena.duckdb

# ── Data paths ───────────────────────────────────────────────────────────────
ATHENA_RAW_DATA_DIR=data/raw
ATHENA_PROCESSED_DATA_DIR=data/processed

# ── Logging ──────────────────────────────────────────────────────────────────
ATHENA_LOG_LEVEL=INFO
ATHENA_LOG_DIR=logs

# ── Analytics ────────────────────────────────────────────────────────────────
ATHENA_MIN_MINUTES=450
ATHENA_USE_POSITION_PERCENTILES=true
